# Network Configuration
NEXT_PUBLIC_BSC_MAINNET_RPC=
NEXT_PUBLIC_BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545

# Contract Addresses (BSC Testnet)
# 根据你的实际部署修改这些地址
NEXT_PUBLIC_PHONE_DISTRIBUTION=0x42C739E8CF9DBcbE076993Cf9495858018bE4395
NEXT_PUBLIC_NEXTFLOW_TOKEN=0xba293c1d58FDCBB1827289c59D10C4456E0e3fCB
NEXT_PUBLIC_TOKEN_POOL=0x5494C5aD0d1d8Ab988caF13dc559711299f0628B
NEXT_PUBLIC_USDT=0x98Fe9F8A2d08D7bD55c3207238F6E9aC757B3e88

# Default Referrer Address
NEXT_PUBLIC_DEFAULT_REFERRER=0xA71EC938e19d1809f34788af6354eccD1B8246fc

# TheGraph Configuration
# Development (Testnet) API URL - 从 https://thegraph.com/studio 获取
NEXT_PUBLIC_THEGRAPH_DEV_API_URL=https://api.studio.thegraph.com/query/1744394/nextflow-subgraph/version/latest

# Production (Mainnet) API URL - 从 https://thegraph.com/studio 获取
NEXT_PUBLIC_THEGRAPH_PROD_API_URL=https://gateway.thegraph.com/api/subgraphs/id/YOUR_SUBGRAPH_ID_HERE

# TheGraph Authentication Token (如果需要)
NEXT_PUBLIC_THEGRAPH_AUTH_TOKEN=

# Enable testnet mode (set to 'true' for testnet, 'false' for mainnet)
NEXT_PUBLIC_ENABLE_TESTNETS=true
