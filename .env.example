
NEXT_PUBLIC_BSC_MAINNET_RPC=

# TheGraph Configuration
# Development (Testnet) API URL - 从 https://thegraph.com/studio 获取
NEXT_PUBLIC_THEGRAPH_DEV_API_URL=https://api.studio.thegraph.com/query/YOUR_DEPLOYMENT_ID/nextflow-subgraph

# Production (Mainnet) API URL - 从 https://thegraph.com/studio 获取
NEXT_PUBLIC_THEGRAPH_PROD_API_URL=https://gateway.thegraph.com/api/subgraphs/id/YOUR_SUBGRAPH_ID_HERE

# TheGraph Authentication Token (如果需要)
NEXT_PUBLIC_THEGRAPH_AUTH_TOKEN=your-query-token-if-required

# Enable testnet mode (set to 'true' for testnet, 'false' for mainnet)
NEXT_PUBLIC_ENABLE_TESTNETS=false
